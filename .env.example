# ProofOfTrain deployment credentials.
# Copy this file to `.env` and fill in the value. NEVER commit `.env`.
#
# ACCOUNT_PRIVATE_KEY: a funded GenLayer Bradbury testnet private key used only to
# sign the deployment transaction. Get test GEN from the faucet:
# https://testnet-faucet.genlayer.foundation
ACCOUNT_PRIVATE_KEY=

# Optional. Protocol fee recipient (defaults to the deployer if left blank) and fee in
# basis points (100 = 1%, the default; max 1000 = 10%).
FEE_RECIPIENT=
FEE_BPS=100
